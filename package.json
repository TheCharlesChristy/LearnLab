{
  "name": "learnlab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n content,bundle,vite \"node scripts/build-content.mjs --watch\" \"node scripts/build-python-bundle.mjs --watch\" \"vite\"",
    "build": "node scripts/build-content.mjs && node scripts/build-python-bundle.mjs && vite build && node scripts/size-check.mjs",
    "validate": "node scripts/build-content.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:py": "pytest python/tests",
    "new:module": "node scripts/new-module.mjs",
    "new:item": "node scripts/new-item.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "dexie": "4.4.3",
    "dexie-react-hooks": "4.4.0",
    "katex": "0.17.0",
    "lucide-react": "1.17.0",
    "mathjs": "15.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-router": "7.17.0",
    "recharts": "3.8.1",
    "rehype-katex": "7.0.1",
    "remark-directive": "4.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "shiki": "4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "rollup-plugin-visualizer": "7.0.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.8"
  }
}
