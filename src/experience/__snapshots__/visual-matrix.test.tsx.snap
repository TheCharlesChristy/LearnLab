        <p
          class="mt-1 text-slate-700 dark:text-slate-200"
        >
          Receiver test complete
        </p>
        <button
          class="mt-3 rounded-md bg-amber-700 px-3 py-2 font-semibold text-white"
          type="button"
        >
          Return to checkpoint
        </button>
      </section>
      <section
        class="rounded-xl border border-emerald-300 bg-emerald-50 p-4 dark:border-emerald-700 dark:bg-emerald-950/40"
      >
        <h2
          class="text-lg font-bold outline-none text-slate-950 dark:text-white"
          tabindex="-1"
        >
          Alternate route selected
        </h2>
        <div
          class="mt-1 text-slate-800 dark:text-slate-100"
        >
          You chose to collect another measurement before repairing the relay.
        </div>
      </section>
    </div>
  </section>
</div>
`;

