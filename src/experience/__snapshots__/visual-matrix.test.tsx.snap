            </dt>
            <dd
              class="mt-1"
            >
              <progress
                aria-label="Signal strength"
                class="h-3 w-full accent-indigo-700"
                max="100"
                value="57"
              >
                57% of 100%
              </progress>
              <span
                class="mt-1 block text-sm text-slate-700 dark:text-slate-200"
              >
                57% of 100%
              </span>
            </dd>
          </div>
        </dl>
      </aside>
      <section
        aria-labelledby="_r_j_"
        class="rounded-xl border border-slate-300 p-4 dark:border-slate-600"
      >
        <h2
          class="text-lg font-bold text-slate-950 dark:text-white"
          id="_r_j_"
        >
          Tools and capabilities
        </h2>
        <ul
          class="mt-3 space-y-2"
        >
          <li>
            <p
              class="font-semibold text-slate-900 dark:text-white"
            >
              <span
                class="sr-only"
              >
                Unlocked: 
