          class="text-lg font-bold outline-none text-slate-950 dark:text-white"
          tabindex="-1"
        >
          Mission complete
        </h2>
        <div
          class="mt-1 text-slate-800 dark:text-slate-100"
        >
          The relay is transmitting again, and the station can receive storm data.
        </div>
      </section>
    </div>
  </section>
</div>
`;
