              Field meter
               
              <span
                aria-hidden="true"
              >
                (
                Unlocked
                )
              </span>
            </p>
            <p
              class="text-sm text-slate-700 dark:text-slate-200"
            >
              Measures relay signal strength.
            </p>
          </li>
          <li>
            <p
              class="font-semibold text-slate-900 dark:text-white"
            >
              <span
                class="sr-only"
              >
                Locked: 
              </span>
              Repair kit
               
              <span
                aria-hidden="true"
              >
                (
                Locked
                )
              </span>
            </p>
            <p
              class="text-sm text-slate-700 dark:text-slate-200"
            >
              Enables a connector repair.
            </p>
          </li>
        </ul>
      </section>
      <section
        aria-label="Mission checkpoint"
        class="rounded-xl border border-amber-300 bg-amber-50 p-4 dark:border-amber-700 dark:bg-amber-950/30"
      >
        <h2
          class="font-bold text-slate-950 dark:text-white"
