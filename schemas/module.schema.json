{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "module.schema.json",
  "title": "LearnLab module.json (SRS §4.4)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "estMinutes",
    "prerequisites",
    "objectives",
    "lessons",
    "version",
    "authors"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "estMinutes": { "type": "integer" },
    "prerequisites": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" }
    },
    "objectives": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 2,
      "maxItems": 6
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "file", "estMinutes"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "title": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["markdown", "python", "screens"] },
          "estMinutes": { "type": "integer" }
        }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "passMark"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "passMark": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "authors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "maxLength": 64
    }
  }
}
